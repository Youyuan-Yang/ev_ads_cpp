<?xml version="1.0" encoding="UTF-8"?>
<scenario name="imu_lean_in_curve" duration_s="5.0">
  <description>roll 较大 + yaw_rate 较高 + 前方有风险，期望报警但 brake safety gate 禁止制动。</description>
  <events>
    <event t="0.0">
      <imu roll="0.5" yaw_rate="0.8" motion_flags="0x02"/>
    </event>
    <event t="1.0">
      <front primary_class="2" distance_m="10" closing_speed_mps="6"/>
    </event>
    <event t="3.0">
      <front primary_class="2" distance_m="4" closing_speed_mps="6"/>
      <imu roll="0.6" yaw_rate="0.9" motion_flags="0x02"/>
    </event>
  </events>
  <assertions max_level_at_least="2" brake_enable_must_be_false="true"/>
</scenario>
