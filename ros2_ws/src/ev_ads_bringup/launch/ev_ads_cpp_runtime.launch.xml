<launch>
  <!-- 统一入口：转发到 C++ runtime XML launch。 -->
  <arg name="use_fakes" default="true"/>
  <arg name="perception_mode" default="scripted"/>
  <arg name="imu_driver" default="i2c"/>
  <arg name="mmwave_mode" default="ble"/>
  <arg name="fusion_profile" default="urban_day"/>
  <arg name="rear_model_path" default=""/>
  <arg name="driver_model_path" default=""/>
  <arg name="driver_face_model_path" default=""/>
  <arg name="enable_real_brake" default="false"/>
  <arg name="event_storage_backend" default="sqlite"/>
  <arg name="event_log_path" default="/tmp/ev_ads/events.sqlite"/>

  <include file="$(find-pkg-share ev_ads_runtime_cpp)/launch/cpp_runtime.launch.xml">
    <arg name="use_fakes" value="$(var use_fakes)"/>
    <arg name="perception_mode" value="$(var perception_mode)"/>
    <arg name="imu_driver" value="$(var imu_driver)"/>
    <arg name="mmwave_mode" value="$(var mmwave_mode)"/>
    <arg name="fusion_profile" value="$(var fusion_profile)"/>
    <arg name="rear_model_path" value="$(var rear_model_path)"/>
    <arg name="driver_model_path" value="$(var driver_model_path)"/>
    <arg name="driver_face_model_path" value="$(var driver_face_model_path)"/>
    <arg name="enable_real_brake" value="$(var enable_real_brake)"/>
    <arg name="event_storage_backend" value="$(var event_storage_backend)"/>
    <arg name="event_log_path" value="$(var event_log_path)"/>
  </include>
</launch>
