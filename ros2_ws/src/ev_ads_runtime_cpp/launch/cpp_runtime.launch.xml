<launch>
  <!-- C++ 运行链路：业务运行参数统一写在 ROS2 XML launch 中。 -->
  <arg name="use_fakes" default="true"/>
  <arg name="perception_mode" default="scripted"/>
  <arg name="imu_driver" default="i2c"/>
  <arg name="mmwave_mode" default="ble"/>

  <!-- 摄像头稳定路径。实车部署时优先使用 /dev/v4l/by-id，避免 /dev/videoN 漂移。 -->
  <arg name="front_camera_device" default="/dev/v4l/by-id/usb-Sony_IMX415-video-index0"/>
  <arg name="rear_camera_device" default="/dev/v4l/by-id/usb-DH-200W-X1-video-index0"/>
  <arg name="driver_camera_device" default="/dev/v4l/by-id/usb-Driver_Cam-video-index0"/>

  <!-- ONNX 模型路径。空路径表示对应模型不启用。 -->
  <arg name="rear_model_path" default=""/>
  <arg name="driver_model_path" default=""/>
  <arg name="driver_face_model_path" default=""/>

  <!-- 融合模型默认使用城市白天参数；需要夜间/长途时直接覆盖这些 launch 参数。 -->
  <arg name="fusion_profile" default="urban_day"/>
  <arg name="w_front" default="0.35"/>
  <arg name="w_rear" default="0.25"/>
  <arg name="w_driver" default="0.20"/>
  <arg name="w_imu" default="0.15"/>
  <arg name="w_mmwave" default="0.05"/>
  <arg name="thr_l1" default="0.30"/>
  <arg name="thr_l2" default="0.55"/>
  <arg name="thr_l3" default="0.75"/>
  <arg name="front_ttc_l3" default="1.2"/>
  <arg name="enable_real_brake" default="false"/>

  <!-- 事件记录默认使用 SQLite/WAL，JSONL 只作为兼容后端。 -->
  <arg name="event_storage_backend" default="sqlite"/>
  <arg name="event_log_path" default="/tmp/ev_ads/events.sqlite"/>

  <node pkg="ev_ads_runtime_cpp" exec="mmwave_node_cpp" name="mmwave_node" output="screen" if="$(var use_fakes)">
    <param name="mode" value="fake"/>
    <param name="publish_rate_hz" value="10.0"/>
  </node>
  <node pkg="ev_ads_runtime_cpp" exec="mmwave_node_cpp" name="mmwave_node" output="screen" unless="$(var use_fakes)">
    <param name="mode" value="$(var mmwave_mode)"/>
    <param name="publish_rate_hz" value="10.0"/>
  </node>

  <node pkg="ev_ads_runtime_cpp" exec="camera_node_cpp" name="camera_front" output="screen" if="$(var use_fakes)">
    <param name="name" value="front"/>
    <param name="mode" value="fake"/>
    <param name="device" value="$(var front_camera_device)"/>
    <param name="width" value="1920"/>
    <param name="height" value="1080"/>
    <param name="fps" value="30.0"/>
    <param name="pixel_format" value="MJPG"/>
    <param name="jpeg_quality" value="80"/>
  </node>
  <node pkg="ev_ads_runtime_cpp" exec="camera_node_cpp" name="camera_front" output="screen" unless="$(var use_fakes)">
    <param name="name" value="front"/>
    <param name="mode" value="device"/>
    <param name="device" value="$(var front_camera_device)"/>
    <param name="width" value="1920"/>
    <param name="height" value="1080"/>
    <param name="fps" value="30.0"/>
    <param name="pixel_format" value="MJPG"/>
    <param name="jpeg_quality" value="80"/>
  </node>

  <node pkg="ev_ads_runtime_cpp" exec="camera_node_cpp" name="camera_rear" output="screen" if="$(var use_fakes)">
    <param name="name" value="rear"/>
    <param name="mode" value="fake"/>
    <param name="device" value="$(var rear_camera_device)"/>
    <param name="width" value="1920"/>
    <param name="height" value="1080"/>
    <param name="fps" value="30.0"/>
    <param name="pixel_format" value="MJPG"/>
    <param name="jpeg_quality" value="80"/>
  </node>
  <node pkg="ev_ads_runtime_cpp" exec="camera_node_cpp" name="camera_rear" output="screen" unless="$(var use_fakes)">
    <param name="name" value="rear"/>
    <param name="mode" value="device"/>
    <param name="device" value="$(var rear_camera_device)"/>
    <param name="width" value="1920"/>
    <param name="height" value="1080"/>
    <param name="fps" value="30.0"/>
    <param name="pixel_format" value="MJPG"/>
    <param name="jpeg_quality" value="80"/>
  </node>

  <node pkg="ev_ads_runtime_cpp" exec="camera_node_cpp" name="camera_driver" output="screen" if="$(var use_fakes)">
    <param name="name" value="driver"/>
    <param name="mode" value="fake"/>
    <param name="device" value="$(var driver_camera_device)"/>
    <param name="width" value="1280"/>
    <param name="height" value="720"/>
    <param name="fps" value="25.0"/>
    <param name="pixel_format" value="MJPG"/>
    <param name="jpeg_quality" value="80"/>
  </node>
  <node pkg="ev_ads_runtime_cpp" exec="camera_node_cpp" name="camera_driver" output="screen" unless="$(var use_fakes)">
    <param name="name" value="driver"/>
    <param name="mode" value="device"/>
    <param name="device" value="$(var driver_camera_device)"/>
    <param name="width" value="1280"/>
    <param name="height" value="720"/>
    <param name="fps" value="25.0"/>
    <param name="pixel_format" value="MJPG"/>
    <param name="jpeg_quality" value="80"/>
  </node>

  <node pkg="ev_ads_runtime_cpp" exec="imu_node_cpp" name="imu_node" output="screen" if="$(var use_fakes)">
    <param name="driver" value="fake"/>
    <param name="port" value="/dev/ttyUSB0"/>
    <param name="baud" value="921600"/>
    <param name="bus" value="1"/>
    <param name="addr" value="104"/>
    <param name="rate_hz" value="100.0"/>
    <param name="publish_imu" value="true"/>
    <param name="mount_rpy_deg" value="[0.0, 0.0, 0.0]"/>
    <param name="lowpass_alpha" value="0.2"/>
    <param name="bias_seconds" value="2.0"/>
    <param name="hard_brake_g" value="0.6"/>
    <param name="lean_deg" value="25.0"/>
    <param name="bump_jerk" value="30.0"/>
    <param name="frame_id" value="imu_link"/>
  </node>
  <node pkg="ev_ads_runtime_cpp" exec="imu_node_cpp" name="imu_node" output="screen" unless="$(var use_fakes)">
    <param name="driver" value="$(var imu_driver)"/>
    <param name="port" value="/dev/ttyUSB0"/>
    <param name="baud" value="921600"/>
    <param name="bus" value="1"/>
    <param name="addr" value="104"/>
    <param name="rate_hz" value="100.0"/>
    <param name="publish_imu" value="true"/>
    <param name="mount_rpy_deg" value="[0.0, 0.0, 0.0]"/>
    <param name="lowpass_alpha" value="0.2"/>
    <param name="bias_seconds" value="2.0"/>
    <param name="hard_brake_g" value="0.6"/>
    <param name="lean_deg" value="25.0"/>
    <param name="bump_jerk" value="30.0"/>
    <param name="frame_id" value="imu_link"/>
  </node>

  <node pkg="ev_ads_runtime_cpp" exec="front_node_cpp" name="front_perception_node" output="screen">
    <param name="publish_rate_hz" value="10.0"/>
    <param name="fake_mode" value="$(var perception_mode)"/>
    <param name="require_camera_health" value="true"/>
    <param name="camera_timeout_ms" value="1000"/>
  </node>

  <node pkg="ev_ads_runtime_cpp" exec="rear_node_cpp" name="rear_perception_node" output="screen">
    <param name="publish_rate_hz" value="10.0"/>
    <param name="fake_mode" value="$(var perception_mode)"/>
    <param name="require_camera_health" value="true"/>
    <param name="camera_timeout_ms" value="1000"/>
    <param name="model_timeout_ms" value="500"/>
    <param name="model_path" value="$(var rear_model_path)"/>
    <param name="model_input_width" value="640"/>
    <param name="model_input_height" value="640"/>
    <param name="model_confidence_threshold" value="0.35"/>
    <param name="model_nms_threshold" value="0.45"/>
    <param name="model_has_objectness" value="false"/>
    <param name="model_class_ids" value="[0, 1, 2, 3, 5, 7]"/>
    <param name="distance_focal_px" value="700.0"/>
    <param name="present_max_m" value="10.0"/>
    <param name="approaching_speed_mps" value="1.0"/>
    <param name="fisheye_undistort" value="false"/>
    <param name="fisheye_k" value="[700.0, 700.0, 960.0, 540.0]"/>
    <param name="fisheye_d" value="[0.0, 0.0, 0.0, 0.0]"/>
    <param name="fisheye_balance" value="0.25"/>
    <param name="fisheye_fov_scale" value="1.0"/>
  </node>

  <node pkg="ev_ads_runtime_cpp" exec="driver_monitor_node_cpp" name="driver_monitor_node" output="screen">
    <param name="publish_rate_hz" value="10.0"/>
    <param name="fake_mode" value="$(var perception_mode)"/>
    <param name="require_camera_health" value="true"/>
    <param name="camera_timeout_ms" value="1000"/>
    <param name="model_timeout_ms" value="500"/>
    <param name="model_path" value="$(var driver_model_path)"/>
    <param name="face_model_path" value="$(var driver_face_model_path)"/>
    <param name="model_input_width" value="640"/>
    <param name="model_input_height" value="640"/>
    <param name="model_confidence_threshold" value="0.35"/>
    <param name="model_nms_threshold" value="0.45"/>
    <param name="model_has_objectness" value="false"/>
    <param name="model_class_ids" value="[]"/>
    <param name="face_class_ids" value="[]"/>
    <param name="open_eye_class_ids" value="[0]"/>
    <param name="half_eye_class_ids" value="[1]"/>
    <param name="closed_eye_class_ids" value="[2]"/>
    <param name="yawn_class_ids" value="[3]"/>
    <param name="phone_class_ids" value="[5]"/>
    <param name="distracted_class_ids" value="[6]"/>
    <param name="fatigue_class_ids" value="[]"/>
    <param name="face_input_width" value="320"/>
    <param name="face_input_height" value="320"/>
    <param name="face_score_threshold" value="0.60"/>
    <param name="face_nms_threshold" value="0.30"/>
    <param name="face_top_k" value="5000"/>
    <param name="face_absence_warning_ms" value="1500"/>
    <param name="face_absence_score" value="0.65"/>
  </node>

  <node pkg="ev_ads_runtime_cpp" exec="fusion_node_cpp" name="fusion_node" output="screen">
    <param name="publish_rate_hz" value="20.0"/>
    <param name="profile" value="$(var fusion_profile)"/>
    <param name="w_front" value="$(var w_front)" type="double"/>
    <param name="w_rear" value="$(var w_rear)" type="double"/>
    <param name="w_driver" value="$(var w_driver)" type="double"/>
    <param name="w_imu" value="$(var w_imu)" type="double"/>
    <param name="w_mmwave" value="$(var w_mmwave)" type="double"/>
    <param name="thr_l1" value="$(var thr_l1)" type="double"/>
    <param name="thr_l2" value="$(var thr_l2)" type="double"/>
    <param name="thr_l3" value="$(var thr_l3)" type="double"/>
    <param name="hysteresis" value="0.05"/>
    <param name="front_ttc_l3" value="$(var front_ttc_l3)" type="double"/>
    <param name="enable_real_brake" value="$(var enable_real_brake)" type="bool"/>
    <param name="zero_stale" value="true"/>
    <param name="stale_reliability" value="0.25"/>
    <param name="weighted_gain" value="0.72"/>
    <param name="probabilistic_gain" value="0.28"/>
    <param name="synergy_gain" value="0.12"/>
    <param name="consensus_bonus" value="0.08"/>
    <param name="front_emergency_ttc" value="0.8"/>
    <param name="front_warning_ttc" value="2.5"/>
    <param name="front_l3_floor" value="0.78"/>
    <param name="front_stale_ms" value="500"/>
    <param name="front_disc_ms" value="3000"/>
    <param name="rear_stale_ms" value="500"/>
    <param name="rear_disc_ms" value="3000"/>
    <param name="driver_stale_ms" value="500"/>
    <param name="driver_disc_ms" value="3000"/>
    <param name="imu_stale_ms" value="200"/>
    <param name="imu_disc_ms" value="1000"/>
    <param name="mmwave_stale_ms" value="500"/>
    <param name="mmwave_disc_ms" value="3000"/>
  </node>

  <node pkg="ev_ads_runtime_cpp" exec="hmi_node_cpp" name="hmi_node" output="screen">
    <param name="dashboard_rate_hz" value="2.0"/>
  </node>

  <node pkg="ev_ads_runtime_cpp" exec="event_logger_node_cpp" name="event_logger_node" output="screen">
    <param name="storage_backend" value="$(var event_storage_backend)"/>
    <param name="log_path" value="$(var event_log_path)"/>
    <param name="flush_every_n" value="32"/>
  </node>
</launch>
