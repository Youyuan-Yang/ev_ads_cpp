# EV-ADS camera aliases for RK3588.
# Match UVC cameras by USB VID/PID and expose stable /dev/ev_ads/* symlinks.
#
# rear_fisheye: A68-1600W, 1bcf:2281
# driver_face: WebCamera, 32e6:9221
# front_camera: ocal4, 1bcf:28c5

SUBSYSTEM=="video4linux", ATTRS{idVendor}=="1bcf", ATTRS{idProduct}=="2281", ATTR{index}=="0", SYMLINK+="ev_ads/rear_fisheye"
SUBSYSTEM=="video4linux", ATTRS{idVendor}=="32e6", ATTRS{idProduct}=="9221", ATTR{index}=="0", SYMLINK+="ev_ads/driver_face"
SUBSYSTEM=="video4linux", ATTRS{idVendor}=="1bcf", ATTRS{idProduct}=="28c5", ATTR{index}=="0", SYMLINK+="ev_ads/front_camera"
